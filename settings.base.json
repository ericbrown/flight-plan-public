{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-scan.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-hint.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/destructive-ops-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-formatter.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/post-edit-test-runner.sh"
          }
        ]
      },
      {
        "matcher": "mcp__memorygraph__store_memory|mcp__memorygraph__update_memory|mcp__memorygraph__create_relationship",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/mcp-activity-log.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git branch*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push origin*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(git tag*)",
      "Bash(git worktree*)",
      "Bash(git remote -v)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bun *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(prettier *)",
      "Bash(mkdir -p *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(chmod +x *)",
      "Bash(touch *)",
      "Bash(date *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push -f)",
      "Bash(sudo rm*)",
      "Bash(rm -rf /)"
    ]
  }
}
