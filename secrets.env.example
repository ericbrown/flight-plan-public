# flight-plan secrets — TEMPLATE (committed). Copy to secrets.env and fill in.
#
#   cp secrets.env.example secrets.env
#   # edit secrets.env, paste your real keys
#   ./install.sh          # wires secrets.env into your shell profile
#   source ~/.zshrc       # (or open a new terminal)
#
# secrets.env is gitignored — it never gets committed. This file (.example) has no
# real keys and is safe to commit. A key cannot securely travel inside the repo, so
# each machine gets its own secrets.env (one paste, or scp it between your machines).

# OpenRouter — one key reaches any model (Gemini 3.1 Pro, Perplexity Sonar, etc.)
export OPENROUTER_API_KEY="sk-or-..."

# Optional model overrides for the second-opinion / reviewing-docs helper:
# export OPENROUTER_MODEL="google/gemini-3.1-pro-preview"   # default reasoning model
# export REVIEW_PROVIDER="openrouter"                       # force the provider

# Other providers (optional — only if you use them directly):
# export GEMINI_API_KEY=""
# export OPENAI_API_KEY=""
# export GITHUB_TOKEN=""
